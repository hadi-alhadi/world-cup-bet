# --- Database (Turso / libSQL) ---
# Local dev: a file URL works for both the Prisma CLI and the libSQL runtime adapter.
DATABASE_URL="file:./dev.db"
# Production (Turso): set these instead; runtime adapter prefers them when present.
# TURSO_DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-token"

# --- Auth ---
# Dev mode: enables the "Sign in as..." mock login (no Google needed). Set false in prod.
AUTH_DEV_MODE="true"
NEXTAUTH_SECRET="dev-secret-change-me-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Real Google OAuth (added later). hd + signIn callback restrict to @privilee.ae.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Comma-separated admin emails -> role ADMIN on sign-in.
ADMIN_EMAILS="ha@privilee.ae"

# --- Fixtures provider ---
# "seed" (default, offline) or "thesportsdb" (free, no key required).
FIXTURES_PROVIDER="seed"
# TheSportsDB free/test key (public test key is "3").
THESPORTSDB_KEY="3"
# Competition/season for the live provider (World Cup example).
THESPORTSDB_LEAGUE_ID="4429"
THESPORTSDB_SEASON="2026"

# --- Cron / sync protection ---
CRON_SECRET="dev-cron-secret"
