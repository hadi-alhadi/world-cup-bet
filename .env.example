# --- Database (Turso / libSQL) ---
# Local dev: a file URL works for both the Prisma CLI and the libSQL runtime adapter.
DATABASE_URL="file:./dev.db"
# Production (Turso): set these instead; runtime adapter prefers them when present.
# TURSO_DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-token"

# --- Auth ---
# Dev mode: enables the "Sign in as..." mock login (no Google needed). Set false in prod.
AUTH_DEV_MODE="true"
NEXTAUTH_SECRET="dev-secret-change-me-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Real Google OAuth (added later). hd + signIn callback restrict to @privilee.ae.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Comma-separated admin emails -> role ADMIN on sign-in.
ADMIN_EMAILS="ha@privilee.ae"

# --- Fixtures provider ---
# "seed" (offline default), "thesportsdb" (free, no key, partial data), or "apifootball".
FIXTURES_PROVIDER="seed"

# TheSportsDB: public test key "3" works but returns a partial schedule.
THESPORTSDB_KEY="3"
THESPORTSDB_LEAGUE_ID="4429"   # 4429 = FIFA World Cup
THESPORTSDB_SEASON="2026"

# API-Football (api-sports.io). One /fixtures call per sync returns the whole schedule
# with teams embedded => 1 request/sync. League 1 = FIFA World Cup. Free plan exposes
# seasons 2022-2024 only (2026 needs a paid plan); 2022 = WC Qatar (full 64 matches).
API_FOOTBALL_KEY=""
API_FOOTBALL_LEAGUE_ID="1"
API_FOOTBALL_SEASON="2022"

# --- Cron / sync protection ---
CRON_SECRET="dev-cron-secret"
# Minimum minutes between syncs (protects metered providers' daily quota). 0 = off.
SYNC_MIN_INTERVAL_MINUTES="360"
